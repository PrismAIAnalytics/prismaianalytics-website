# prismaianalytics.com — local + build-time environment variables.
#
# Copy this file to `.env` and fill in real values for local builds.
# Production values live in Netlify UI → Site settings → Environment variables.
# Do NOT commit `.env`; it is gitignored.

# GA4 Measurement ID. Format: G-XXXXXXXXXX.
# Get it from https://analytics.google.com → Admin → Data Streams → Web stream.
# Required by scripts/inject-analytics.js to embed the gtag snippet at build.
# If unset, the inject step skips and the build still succeeds (no analytics).
GA_MEASUREMENT_ID=

# Netlify Function env vars (used by netlify/functions/submission-created.js)
DASHBOARD_API_URL=
DASHBOARD_LEADS_SECRET=
