<script>
  // Hero media flag: ?hero=v2 swaps the iStock video for the Three.js prism.
  // Skips on reduced-motion preference, mobile (perf budget + layout collapses
  // to single-column at the same 900px breakpoint as main.css), or import failure.
  (function () {
    const params = new URLSearchParams(window.location.search);
    if (params.get('hero') !== 'v2') return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.matchMedia('(max-width: 900px)').matches) return;

    const canvas = document.getElementById('hero-prism-canvas');
    const video = document.getElementById('hero-video');
    if (!canvas || !video) return;

    import('/hero/prism-animation.js').then(function (mod) {
      video.style.display = 'none';
      canvas.style.display = 'block';
      return mod.mountPrismAnimation(canvas, { svgUrl: '/hero/prism-logo.svg' });
    }).then(function (handle) {
      // Pause the WebGL loop when the canvas scrolls out of view; resume on re-entry.
      const io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) handle.play();
          else handle.pause();
        });
      }, { threshold: 0.01 });
      io.observe(canvas);
    }).catch(function (err) {
      // Defensive: if Three.js fails to load, restore video as fallback so the
      // hero never renders empty.
      video.style.display = 'block';
      canvas.style.display = 'none';
      console.warn('[hero] Three.js failed; falling back to video:', err);
    });
  })();
</script>

