    background: rgba(189,201,221,0.12); color: var(--sky);
  }
  .episode-card-tag.intro-tag,
  .episode-card-tag.finale-tag {
    background: rgba(200,164,90,0.35); color: var(--white);
  }
  .episode-card-date {
