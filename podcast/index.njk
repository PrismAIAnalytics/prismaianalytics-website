    line-height: 1.3; margin: 0 0 0.6rem; letter-spacing: -0.01em;
  }
  .episode-card-body p {
    font-size: 0.92rem; line-height: 1.6; color: var(--text-muted);
    margin: 0 0 1.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }
  .episode-source-link {
    display: inline-flex; align-items: center; gap: 0.4rem;
    color: var(--royal); text-decoration: none;
