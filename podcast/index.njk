---
layout: base.njk
title: "The Prism Podcast | Prism AI Analytics"
description: "AI-generated audio companions to the Prism Configuration Management for AI Agents series. Conversations on enterprise AI governance, built around the CM-AI Framework."
ogTitle: "The Prism Podcast"
ogDescription: "AI-generated audio companions to the Prism CM-AI Framework series. One episode per blog post, building toward the white paper finale."
ogType: "website"
permalink: /podcast/
extraHead: |
  <link rel="stylesheet" href="/assets/css/insights.css?v=5"/>
  <link rel="alternate" type="application/rss+xml" title="The Prism Podcast" href="https://micheleprismai.substack.com/feed"/>
---

<header class="insights-hero insights-hero--index">
  <div class="insights-hero-inner">
    <p class="insights-eyebrow">{{ podcast.show.eyebrow }}</p>
    <h1>{{ podcast.show.h1 }}</h1>
    <p class="insights-dek">{{ podcast.show.dek }}</p>
  </div>
</header>

{# Platform-links row — only renders pills for platforms with a URL configured.
   Spotify/Apple stay hidden until the show is submitted to those directories. #}
<nav class="platform-links" aria-label="Listen on">
  {% for p in podcast.platformsActive %}<a class="platform-link" href="{{ p.url }}" target="_blank" rel="noopener noreferrer">{{ p.label }}</a>{% endfor %}
</nav>

{# Latest episodes — 2-col grid #}
<section class="episodes-latest" aria-label="Latest episodes">
  {% for ep in podcast.latest %}
  <article class="episode-card--latest reveal">
    <div class="episode-card-head">
      <span class="episode-number">{{ ep.number }}</span>
      <span class="episode-meta">
        <time datetime="{{ ep.date }}">{{ ep.dateFormatted }}</time>
        {% if ep.duration %}<span class="meta-sep" aria-hidden="true"></span><span>{{ ep.duration }}</span>{% endif %}
      </span>
    </div>
    <div class="episode-card-body">
      <h3>{{ ep.title }}</h3>
      <p>{{ ep.brief }}</p>
      {% if ep.relatedPostUrl %}<a class="episode-related" href="{{ ep.relatedPostUrl }}">Related reading: {{ ep.relatedPostLabel }} →</a>{% endif %}
    </div>
    <details class="episode-player">
      <summary>Listen</summary>
      <div class="podcast-player-frame">
        <iframe src="{{ ep.embedUrl }}" scrolling="no" loading="lazy" title="{{ ep.title }} on Substack"></iframe>
      </div>
      <p class="episode-player-listen-fallback">Player not loading? <a href="{{ ep.listenUrl }}" target="_blank" rel="noopener noreferrer">Listen on Substack →</a></p>
    </details>
  </article>
  {% endfor %}
</section>

{# All episodes — denser row list of everything except the latest 2 #}
{% if podcast.rest.length > 0 %}
<section class="episodes-all" aria-label="All episodes">
  <h2 class="episodes-all-heading">All Episodes</h2>
  {% for ep in podcast.rest %}
  <details class="episode-card--row">
    <summary>
      <span class="episode-number">{{ ep.number }}</span>
      <span class="episode-row-title">{{ ep.title }}</span>
      <time class="episode-row-date" datetime="{{ ep.date }}">{{ ep.dateFormatted }}</time>
    </summary>
    <div class="episode-row-body">
      <p>{{ ep.brief }}</p>
      {% if ep.relatedPostUrl %}<p><a class="episode-related" href="{{ ep.relatedPostUrl }}">Related reading: {{ ep.relatedPostLabel }} →</a></p>{% endif %}
      <div class="podcast-player-frame">
        <iframe src="{{ ep.embedUrl }}" scrolling="no" loading="lazy" title="{{ ep.title }} on Substack"></iframe>
      </div>
      <p class="episode-player-listen-fallback">Player not loading? <a href="{{ ep.listenUrl }}" target="_blank" rel="noopener noreferrer">Listen on Substack →</a></p>
    </div>
  </details>
  {% endfor %}
</section>
{% endif %}

<aside class="podcast-disclosure">
  <strong>About these episodes.</strong>
  Episodes are produced with Google NotebookLM from Prism's own written material — white papers, blog posts, and field notes. They are conversational summaries, not original reporting. Voices are synthetic. Every episode links back to the underlying written source so any claim can be verified against the original document.
</aside>

{# PodcastSeries + PodcastEpisode JSON-LD #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "PodcastSeries",
  "name": "{{ podcast.show.title }}",
  "description": "{{ podcast.show.dek }}",
  "url": "{{ site.url }}/podcast/",
  "webFeed": "{{ podcast.show.rssUrl }}",
  "author": { "@type": "Organization", "name": "{{ site.name }}", "url": "{{ site.url }}" }
}
</script>
{% for ep in podcast.episodes %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "PodcastEpisode",
  "name": {{ ep.title | dump | safe }},
  "datePublished": "{{ ep.date }}",
  "description": {{ ep.brief | dump | safe }},
  "url": "{{ ep.listenUrl }}",
  "associatedMedia": {
    "@type": "MediaObject",
    "contentUrl": "{{ ep.listenUrl }}"
  },
  "partOfSeries": {
    "@type": "PodcastSeries",
    "name": "{{ podcast.show.title }}",
    "url": "{{ site.url }}/podcast/"
  }
}
</script>
{% endfor %}
