    overflow: hidden;
    background: var(--offwhite);
    border: 1px solid var(--gray);
  }
  .episode-embed iframe {
    width: 100%;
    border: 0;
    display: block;
    height: 460px;
  }
  @media (max-width: 640px) {
    .episode-embed iframe { height: 400px; }
  }
  .episode-listen {
    margin-top: 0.75rem;
    font-size: 0.78rem; color: var(--text-muted);
  }
  .episode-listen a {
    color: var(--royal); text-decoration: none; font-weight: 600;
  }
  .episode-listen a:hover { color: var(--navy); }

  /* Upcoming episode variant — muted treatment for unpublished cards */
  .episode-card.upcoming { background: transparent; border-style: dashed; }
  .episode-card.upcoming:hover { box-shadow: none; border-color: var(--sky); }
  .episode-card.upcoming .episode-card-header {
