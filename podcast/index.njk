  }
  .episode-card.upcoming .episode-card-body h2 { color: var(--text-muted); }

  .podcast-disclosure {
    margin-top: 3rem;
    padding: 1.25rem 1.5rem;
    background: var(--white);
    border-left: 3px solid var(--gold);
    border-radius: 6px;
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--text-muted);
  }
  .podcast-disclosure strong { color: var(--navy); }

  @media (max-width: 900px) {
    .podcast-hero { padding: 7rem 1.5rem 3rem; }
    .podcast-section { padding: 3rem 1.5rem 4rem; }
    .episode-card-header { padding: 1rem 1.15rem; }
    .episode-card-body { padding: 1.15rem 1.15rem 1.4rem; }
    .episode-card-date { margin-left: 0; width: 100%; }
  }
